{
    "name": "@wavoip/wavoip-api",
    "version": "2.4.2",
    "license": "MIT",
    "main": "dist/index.umd.js",
    "types": "dist/index.d.ts",
    "module": "dist/index.es.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        }
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wavoip/wavoip-api.git"
    },
    "scripts": {
        "dev": "vite",
        "lint": "pnpm exec tsc --noEmit && pnpm exec biome lint --fix .",
        "build": "vite build",
        "build:pack": "pnpm pre-deploy && pnpm pack",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "pre-deploy": "pnpm lint && pnpm test && pnpm build"
    },
    "packageManager": "pnpm@10.7.1",
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/node": "^22.14.0",
        "@vitest/coverage-v8": "^4.1.2",
        "happy-dom": "^20.8.9",
        "ts-node": "^10.9.2",
        "typescript": "~5.7.2",
        "vite": "^6.4.2",
        "vite-plugin-dts": "^4.5.3",
        "vite-plugin-externalize-deps": "^0.9.0",
        "vite-plugin-static-copy": "^3.1.2",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "a18n": "^1.12.4",
        "axios": "^1.16.1",
        "socket.io-client": "^4.8.3"
    },
    "pnpm": {
        "overrides": {
            "brace-expansion@1": ">=1.1.12",
            "brace-expansion@2": ">=2.0.2",
            "lodash": ">=4.17.23",
            "diff@4": ">=4.0.4",
            "minimatch@<3.1.3": ">=3.1.3",
            "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
            "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
            "rollup@4": ">=4.59.0",
            "ajv@8": ">=8.18.0",
            "socket.io-parser@4": ">=4.2.6",
            "picomatch@2": ">=2.3.2",
            "picomatch@4": ">=4.0.4",
            "postcss": ">=8.5.10",
            "ws@8": ">=8.20.1"
        }
    }
}
